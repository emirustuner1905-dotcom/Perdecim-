@{
    Layout = null; // Menülerin gelmemesi için layout'u sıfırlıyoruz.
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PerdeCim - Yönetici Girişi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 50%, #cbd5e1 100%);
            --card-bg: #ffffff;
            --text-dark: #0f172a;
            --text-muted: #64748b;
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --border-color: #e2e8f0;
            --input-bg: #f8fafc;
        }

        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        body {
            background: var(--bg-gradient);
            font-family: 'Plus Jakarta Sans', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-box {
            background: var(--card-bg);
            border: 1px solid rgba(255, 255, 255, 0.7);
            border-radius: 28px;
            padding: 45px 40px;
            box-shadow: 0 25px 60px -15px rgba(15, 23, 42, 0.12), 
                        0 20px 40px -20px rgba(15, 23, 42, 0.05);
            width: 100%;
            max-width: 450px;
            animation: fadeInUp 0.6s ease-out;
        }

        .login-box h3 {
            color: var(--text-dark);
            font-weight: 800;
            letter-spacing: -0.03em;
            font-size: 1.75rem;
        }

        .login-box p {
            color: var(--text-muted);
            font-weight: 500;
        }

        .form-group-custom {
            position: relative;
            margin-bottom: 20px;
        }

        .form-group-custom i {
            position: absolute;
            left: 18px;
            top: 48px;
            color: var(--text-muted);
            font-size: 1.1rem;
            transition: color 0.3s ease;
        }

        .custom-label {
            color: var(--text-dark);
            font-size: 0.8rem;
            font-weight: 700;
            margin-bottom: 8px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .custom-input {
            background: var(--input-bg) !important;
            border: 2px solid var(--border-color) !important;
            border-radius: 14px !important;
            padding: 14px 14px 14px 52px !important;
            color: var(--text-dark) !important;
            font-weight: 500;
            height: 54px;
            transition: all 0.25s ease;
        }

        .custom-input:focus {
            border-color: var(--primary) !important;
            background: #ffffff !important;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1) !important;
        }

        .form-group-custom:focus-within i {
            color: var(--primary);
        }

        /* Ana Giriş Butonu */
        .btn-premium-indigo {
            background: linear-gradient(135deg, var(--primary) 0%, #6366f1 100%);
            border: none;
            color: #ffffff;
            font-weight: 700;
            font-size: 0.95rem;
            padding: 14px;
            border-radius: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            height: 54px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
        }

        .btn-premium-indigo:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3);
            filter: brightness(1.05);
        }

        /* İkincil Butonlar (Temizle ve Çıkış) */
        .btn-premium-outline {
            background: transparent;
            border: 2px solid #f1f5f9;
            color: #64748b;
            font-weight: 600;
            padding: 10px;
            border-radius: 14px;
            height: 46px;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .btn-premium-outline:hover {
            background: #f8fafc;
            color: var(--text-dark);
            border-color: #cbd5e1;
        }

        .btn-premium-danger {
            background: transparent;
            border: 2px solid #fee2e2;
            color: #ef4444;
            font-weight: 600;
            padding: 10px;
            border-radius: 14px;
            height: 46px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-premium-danger:hover {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
        }

        .alert-custom {
            background-color: #fef2f2;
            border: 1px solid #fee2e2;
            color: #ef4444;
            border-radius: 12px;
            padding: 12px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="login-box">
        <div class="text-center mb-4">
            <h3>Yönetici Girişi</h3>
            <p class="small">PerdeCim panel erişimi için bilgilerinizi doğrulayın.</p>
        </div>

        @if (ViewBag.Hata != null)
        {
            <div class="alert alert-custom text-center mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Hata
            </div>
        }

        <form asp-controller="Login" asp-action="SignIn" method="POST">
            <div class="form-group-custom">
                <label class="custom-label">Kullanıcı Adı</label>
                <i class="bi bi-person-fill"></i>
                <input type="text" name="userName" placeholder="Yönetici adınız" class="form-control custom-input" required autocomplete="off" />
            </div>

            <div class="form-group-custom">
                <label class="custom-label">Şifre</label>
                <i class="bi bi-lock-fill"></i>
                <input type="password" name="userPass" placeholder="Şifreniz" class="form-control custom-input" required />
            </div>

            <div class="mt-4 pt-2">
                <button type="submit" class="btn btn-premium-indigo w-100 mb-3">
                    <i class="bi bi-shield-lock-fill me-2"></i> Giriş Yap
                </button>
                
                <div class="row g-2">
                    <div class="col-6">
                        <button type="reset" class="btn btn-premium-outline w-100">
                            <i class="bi bi-eraser-fill me-1"></i> Temizle
                        </button>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-premium-danger w-100">
                            <i class="bi bi-house-door-fill me-1"></i> İptal Et
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>

</body>
</html>