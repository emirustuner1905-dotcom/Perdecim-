@model PerdeCim.Models.Perde

@{
    ViewData["Title"] = "Ürün Ekle - PerdeCim Premium";
}

<style>
    body {
        background: #0f172a; /* Derin lacivert/siyah arka plan */
        font-family: 'Inter', sans-serif;
    }

    .premium-card {
        background: rgba(30, 41, 59, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        color: white;
        margin-top: 50px;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #94a3b8;
        margin-bottom: 8px;
    }

    .form-control {
        background: rgba(15, 23, 42, 0.6) !important;
        border: 1px solid #334155 !important;
        border-radius: 12px !important;
        color: #f8fafc !important;
        padding: 12px 15px;
        transition: 0.3s;
    }

    .form-control:focus {
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        background: rgba(15, 23, 42, 0.8) !important;
    }

    .btn-premium {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
        border: none;
        padding: 15px;
        border-radius: 12px;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: 0.4s;
    }

    .btn-premium:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.4);
        filter: brightness(1.1);
    }

    .input-group-text {
        background: #1e293b;
        border: 1px solid #334155;
        color: #94a3b8;
        border-radius: 12px 0 0 12px !important;
    }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        background: linear-gradient(to right, #fff, #94a3b8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 30px;
    }
</style>

<div class="container d-flex justify-content-center">
    <div class="premium-card col-lg-8 shadow-2xl">
        <div class="text-center">
            <h2 class="section-title">Yeni Koleksiyon Ekle</h2>
            <p class="text-muted mb-5">Veritabanına yeni bir premium perde kaydı oluşturun.</p>
        </div>

        <form asp-controller="PerdeEkle" asp-action="Ekle" method="post">
            <div class="row">
                <!-- Perde Adi -->
                <div class="col-md-6 mb-4">
                    <label class="form-label">Perde Adı</label>
                    <input type="text" name="PerdeAdi" class="form-control" placeholder="Örn: Royal Saten" required>
                </div>
                <!-- Perde Modeli -->
                <div class="col-md-6 mb-4">
                    <label class="form-label">Model Grubu</label>
                    <input type="text" name="PerdeModeli" class="form-control" placeholder="Örn: Tül Perde" required>
                </div>
            </div>

            <div class="row">
                <!-- Kumas Turu -->
                <div class="col-md-6 mb-4">
                    <label class="form-label">Kumaş Türü</label>
                    <input type="text" name="KumasTuru" class="form-control" placeholder="Örn: %100 İpek">
                </div>
                <!-- Perde Fiyati -->
                <div class="col-md-6 mb-4">
                    <label class="form-label">Birim Fiyat (₺)</label>
                    <div class="input-group">
                        <span class="input-group-text">₺</span>
                        <input type="number" name="PerdeFiyati" class="form-control" placeholder="0.00" required>
                    </div>
                </div>
            </div>

            <!-- Perde Gorsel -->
            <div class="mb-4">
                <label class="form-label">Görsel Dosya Yolu veya URL</label>
                <input type="text" name="PerdeGorsel" class="form-control" placeholder="/img/perde-adiniz.jpg">
                <small class="text-info mt-1 d-block">Not: Görsellerin gelmesi için "/img/dosya.jpg" formatında yazın.</small>
            </div>

            <!-- Perde Aciklama -->
            <div class="mb-4">
                <label class="form-label">Ürün Detayları ve Açıklama</label>
                <textarea name="PerdeAciklama" class="form-control" rows="3" placeholder="Ürünün dokusu, ışık geçirgenliği vb."></textarea>
            </div>

            <div class="row">
                <!-- Indirim Orani -->
                <div class="col-md-6 mb-4">
                    <label class="form-label">İndirim Oranı (%)</label>
                    <input type="number" name="IndirimOrani" class="form-control" value="0">
                </div>
                <!-- Stok Adedi -->
                <div class="col-md-6 mb-5">
                    <label class="form-label">Mevcut Stok</label>
                    <input type="number" name="StokAdedi" class="form-control" value="1">
                </div>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-premium">
                    <i class="bi bi-cloud-arrow-up-fill me-2"></i> ÜRÜNÜ VERİTABANINA YÜKLE
                </button>
            </div>
        </form>
    </div>
</div>