<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PerdeCim - Premium Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f8f9fa; color: #1e293b; }
        .sidebar { min-height: 100vh; background: #0f172a; color: #fff; width: 260px; position: fixed; box-shadow: 4px 0 10px rgba(0,0,0,0.05); }
        .sidebar a { color: #94a3b8; text-decoration: none; padding: 14px 24px; display: block; font-weight: 500; border-radius: 8px; margin: 4px 16px; transition: all 0.2s ease; }
        .sidebar a:hover { background: #1e293b; color: #f8fafc; }
        .sidebar a.active { background: #3b82f6; color: #fff; }
        .main-content { margin-left: 260px; padding: 40px; }
        .premium-card { border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02); background: #fff; border: 1px solid #e2e8f0; }
        .form-control-premium { border-radius: 10px; border: 1px solid #cbd5e1; padding: 12px 16px; }
        .form-control-premium:focus { border-color: #3b82f6; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1); }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="p-4 mb-3">
            <h4 class="fw-bold tracking-tight text-white m-0">⚡ PERDECİM</h4>
            <small class="text-muted">Premium Yönetim</small>
        </div>
        <a href="/Admin/Index" class="active">📦 Perde Yönetimi</a>
        <a href="/Admin/Kullanicilar">👥 Kullanıcılar</a>
        <div class="position-absolute bottom-0 w-100 pb-4">
            <a href="/Login/Logout" class="text-danger">🔒 Güvenli Çıkış</a>
        </div>
    </div>

    <div class="main-content">
        @RenderBody()
    </div>

</body>
</html>