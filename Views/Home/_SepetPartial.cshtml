@model List<Perde>

@if (Model != null && Model.Any())
{
    <div class="d-flex flex-column h-100">
        <div class="flex-grow-1 overflow-auto pe-2" style="max-height: 70vh;">
            @foreach (var p in Model)
            {
                <div class="card mb-3 border-0 shadow-sm" style="background: rgba(255,255,255,0.08);">
                    <div class="row g-0 align-items-center p-2">
                        <div class="col-4">
                            <img src="~/img/@p.PerdeGorsel" class="img-fluid rounded" alt="@p.PerdeAdi">
                        </div>
                        <div class="col-8 ps-3">
                            <h6 class="mb-0 text-white">@p.PerdeAdi</h6>
                            <small class="text-primary fw-bold">@p.PerdeFiyati ₺</small>
                            <br>
                            <button onclick="sepettenSil(@p.PerdeId)" class="btn btn-sm btn-link text-danger p-0 mt-1 text-decoration-none">
                                <i class="bi bi-trash"></i> Kaldır
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-3 pt-3 border-top border-secondary">
            <div class="d-flex justify-content-between mb-3 text-white">
                <span class="fw-bold fs-5">Toplam:</span>
                <span class="fw-bold fs-5 text-primary">@Model.Sum(x => x.PerdeFiyati) ₺</span>
            </div>
            <a asp-controller="Home" asp-action="OdemeSecenekleri" class="btn btn-primary w-100 py-3 rounded-3 fw-bold">
                <i class="bi bi-credit-card-2-front"></i> Ödemeye Geç
            </a>
        </div>
    </div>

    <script>
        function sepettenSil(id) {
            // HomeController'daki düzeltilmiş SepettenSil metodu ile haberleşir
            fetch('/Home/SepettenSil?id=' + id, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(response => response.text())
            .then(html => {
                // Gelen güncel HTML'i offcanvas body içine basar
                document.getElementById('sepetBody').innerHTML = html;
            });
        }
    </script>
}
else
{
    <div class="text-center mt-5 text-white-50">
        <i class="bi bi-cart-x fs-1"></i>
        <p class="mt-2">Sepetiniz şu an boş.</p>
        <a asp-controller="Home" asp-action="Modeller" class="btn btn-outline-primary btn-sm mt-2">Alışverişe Başla</a>
    </div>
}