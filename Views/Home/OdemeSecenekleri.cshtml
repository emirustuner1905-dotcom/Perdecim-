<style>
    /* Kart Animasyonu */
    .credit-card-inner { position: relative; width: 350px; height: 200px; text-align: center; transition: transform 0.8s; transform-style: preserve-3d; cursor: pointer; }
    .card:hover .credit-card-inner { transform: rotateY(180deg); }
    .front, .back { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; border-radius: 20px; padding: 25px; }
    .front { background: linear-gradient(135deg, #0f172a, #3b82f6); color: white; }
    .back { background: #1e293b; color: white; transform: rotateY(180deg); display: flex; align-items: center; justify-content: center; }
</style>

<div class="container py-5">
    <div class="row g-5">
        <div class="col-lg-5">
            <h3 class="text-white mb-4">Ödeme Yöntemleri</h3>
            <div class="credit-card-inner mx-auto mb-4">
                <div class="front shadow-lg">
                    <div class="d-flex justify-content-between"><span>VISA</span><i class="bi bi-sim"></i></div>
                    <div class="my-4 fs-4">4444 4444 4444 4444</div>
                    <div class="d-flex justify-content-between"><span>TEST KARTI</span><span>12/26</span></div>
                </div>
                <div class="back shadow-lg">
                    <p>CVV: 123</p>
                </div>
            </div>
            <div class="bg-dark p-4 rounded-4 text-white-50">
                <i class="bi bi-shield-check text-success"></i> 256-bit SSL ile verileriniz şifrelenir.
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card p-5" style="background: rgba(255,255,255,0.05); border: 1px solid #3b82f6; border-radius: 30px; color: white;">
                <h4 class="mb-4">Kart Bilgilerini Gir</h4>
                <form id="odemeFormu">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label>Kart Sahibi</label>
                            <input type="text" class="form-control bg-transparent text-white border-secondary" placeholder="Ad Soyad">
                        </div>
                        <div class="col-md-12 mb-3">
                            <label>Kart Numarası</label>
                            <input type="text" class="form-control bg-transparent text-white border-secondary" placeholder="XXXX XXXX XXXX XXXX">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>Son Kullanma</label>
                            <input type="text" class="form-control bg-transparent text-white border-secondary" placeholder="AA/YY">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>CVV</label>
                            <input type="text" class="form-control bg-transparent text-white border-secondary" placeholder="***">
                        </div>
                    </div>
                    <button type="button" onclick="odemeYap()" class="btn btn-primary w-100 py-3 mt-3 rounded-4">Güvenli Ödemeyi Tamamla</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function odemeYap() {
        alert("Sistem test modundadır! Gerçek entegrasyon için PayTR veya Iyzico API'si bağlanmalıdır.");
    }
</script>