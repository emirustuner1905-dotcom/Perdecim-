@{
    ViewData["Title"] = "Konum";
}

<style>
    .location-container { padding: 50px 0; }
    .location-card {
        background: rgba(30, 41, 59, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }
    /* Tüm yazılar beyaz olsun */
    .location-card h2, .location-card h4, .location-card p, .location-card span {
        color: #ffffff !important;
    }
    .map-box {
        border-radius: 20px;
        overflow: hidden;
        border: 4px solid #3b82f6;
        height: 400px;
    }
    iframe {
        width: 100%;
        height: 100%;
        /* Harita için koyu mod filtre */
        filter: invert(90%) hue-rotate(180deg);
    }
</style>

<div class="location-container container">
    <div class="location-card">
        <h2 class="text-center fw-bold mb-4">Mağaza Konumumuz</h2>
        
        <div class="row align-items-center">
            <div class="col-lg-8">
                <div class="map-box">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3163.6364177579144!2d40.73836377665489!3d37.313362199999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x400b462c19f5664d%3A0x28972b225916053!2sBak%C4%B1rc%C4%B1lar%20%C3%87ar%C5%9F%C4%B1s%C4%B1!5e0!3m2!1str!2str!4v1716190000000!5m2!1str!2str" 
                            allowfullscreen="" loading="lazy"></iframe>
                </div>
            </div>
            
            <div class="col-lg-4 text-center mt-4 mt-lg-0">
                <i class="bi bi-geo-alt-fill" style="font-size: 3rem; color: #3b82f6;"></i>
                <h4 class="mt-3 fw-bold">Perdecim</h4>
                <p class="mt-3">Tarihi Bakırcılar ve Revaklı Çarşı bölgesi.<br>PerdeCim Showroom</p>
                <div class="mt-4">
                    <span class="badge border border-primary p-2" style="background: transparent;">Çalışma Saatleri: 09:00 - 19:30</span>
                </div>
            </div>
        </div>
    </div>
</div>