<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card p-5" style="background: rgba(15, 23, 42, 0.9); border-radius: 30px; border: 1px solid #3b82f6;">
                <h2 class="text-white text-center mb-4">📦 Kargo Takip</h2>
                
                <div class="mb-4">
                    <input type="text" id="kargoNo" class="form-control mb-2" placeholder="Kargo Takip Numarası Girin (Örn: PC12345)" style="background:transparent; border: 1px solid #3b82f6; color:white; border-radius:15px; padding:12px;">
                    <button onclick="takipEt()" class="btn btn-primary w-100 rounded-3">Sorgula</button>
                </div>

                <div id="sonucAlani" class="d-none">
                    <hr style="border-color: #3b82f6;">
                    <div class="d-flex justify-content-between text-white mb-3">
                        <span>Durum:</span>
                        <strong class="text-primary">Yola Çıktı</strong>
                    </div>
                    <div class="progress" style="height: 10px; border-radius: 5px;">
                        <div class="progress-bar bg-primary" style="width: 65%"></div>
                    </div>
                    <p class="text-white-50">Tahmini Teslimat: 22 Mayıs 2026</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function takipEt() {
        const no = document.getElementById('kargoNo').value;
        if(no.length > 3) {
            document.getElementById('sonucAlani').classList.remove('d-none');
        } else {
            alert('Lütfen geçerli bir takip numarası girin!');
        }
    }
</script>