@{ Layout = null; }

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #f1f5f9; display: flex; align-items: center; justify-content: center; height: 100vh; font-family: sans-serif; }
        .register-card { background: white; padding: 40px; border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.05); width: 100%; max-width: 450px; }
        .input-custom { border-radius: 12px; padding: 12px; border: 2px solid #e2e8f0; margin-bottom: 15px; }
        .btn-premium { background: #4f46e5; color: white; border-radius: 12px; padding: 12px; width: 100%; border: none; font-weight: 700; }
    </style>
</head>
<body>

<div class="register-card">
    <h3 class="fw-bold mb-1">Satıcı Kaydı</h3>
    <p class="text-muted mb-4">Aramıza katılmak için bilgilerinizi girin.</p>

    <form asp-controller="Account" asp-action="Register" method="POST">
        <div class="mb-3">
            <label class="form-label fw-bold">Adınız Soyadınız</label>
            <input type="text" name="SaticiAdi" class="form-control input-custom" required />
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Kısa Özgeçmişiniz (CV)</label>
            <textarea name="SaticiCv" class="form-control input-custom" rows="3"></textarea>
        </div>
        <div class="mb-4">
            <label class="form-label fw-bold">Profil Fotoğrafı Linki</label>
            <input type="text" name="SaticiFoto" class="form-control input-custom" placeholder="https://..." />
        </div>
        
        <button type="submit" class="btn btn-premium">Hesabımı Oluştur</button>
        <a asp-action="Login" class="btn btn-link w-100 mt-2 text-decoration-none text-muted">Zaten hesabın var mı? Giriş yap</a>
    </form>
</div>

</body>
</html>