@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PerdeCim - Satıcı Girişi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --primary: #4f46e5; --bg: #f1f5f9; }
        body { background: var(--bg); font-family: sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .login-card { background: white; padding: 40px; border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.05); width: 100%; max-width: 400px; }
        .btn-premium { background: var(--primary); color: white; border-radius: 12px; padding: 12px; font-weight: 700; width: 100%; border: none; }
        .input-custom { border-radius: 12px; padding: 12px; border: 2px solid #e2e8f0; margin-bottom: 15px; }
    </style>
</head>
<body>

<div class="login-card">
    <h3 class="fw-bold mb-1">Satıcı Girişi</h3>
    <p class="text-muted mb-4">Lütfen satış bilgilerinizi giriniz.</p>

    <form asp-controller="Account" asp-action="Login" method="POST">
        <div class="mb-3">
            <label class="form-label fw-bold">Satıcı Adı</label>
            <input type="text" name="SaticiAdi" class="form-control input-custom" required />
        </div>
        <div class="mb-4">
            <label class="form-label fw-bold">Satıcı ID</label>
            <input type="number" name="SaticiId" class="form-control input-custom" required />
        </div>
        <button type="submit" class="btn btn-premium">Panele Giriş Yap</button>
        <a asp-controller="Home" asp-action="Index" class="btn btn-link w-100 mt-2 text-decoration-none text-muted">Ana Sayfaya Dön</a>
    </form>
</div>

</body>
</html>